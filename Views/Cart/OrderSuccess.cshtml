@model int
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container my-5 text-center">
    <div class="py-5">
        <div class="mb-4">
            <i class="fas fa-check-circle fa-5x text-success animate__animated animate__bounceIn"></i>
        </div>
        <h1 class="fw-bold mb-3">Đặt Hàng Thành Công!</h1>
        <p class="lead mb-4">Cảm ơn bạn đã tin tưởng FastFood Store. <br> Mã đơn hàng của bạn là: <strong>#@Model</strong></p>
        <p class="text-muted mb-5">Nhân viên của chúng tôi sẽ sớm gọi điện xác nhận đơn hàng.</p>
        
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-5">Tiếp tục mua sắm</a>
        </div>
    </div>
</div>

@model FastFoodEcommerce.Models.Order
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container my-5">
    <h2 class="section-title">Thông Tin Giao Hàng</h2>

    <div class="row">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 p-4">
                <form asp-action="Checkout" method="post">
                    <div class="mb-3">
                        <label asp-for="CustomerName" class="form-label fw-bold">Họ tên người nhận</label>
                        <input asp-for="CustomerName" class="form-control rounded-3" placeholder="Nguyễn Văn A">
                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label fw-bold">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control rounded-3" placeholder="0901xxxxxx">
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label fw-bold">Địa chỉ nhận hàng</label>
                        <textarea asp-for="Address" class="form-control rounded-3" rows="3" placeholder="Số nhà, tên đường, phường/xã..."></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3">Xác nhận đặt hàng</button>
                </form>
            </div>
        </div>
        <div class="col-lg-5 mt-4 mt-lg-0">
            <div class="card bg-light border-0 rounded-4 p-4">
                <h4 class="mb-3">Tổng cộng thanh toán</h4>
                <div class="d-flex justify-content-between">
                    <span class="h3 fw-bold text-danger">@Model.TotalAmount.ToString("N0")đ</span>
                </div>
                <p class="text-muted small mt-2">Thanh toán bằng tiền mặt khi nhận hàng (COD).</p>
                <hr>
                <p class="small"><i class="fas fa-info-circle me-2"></i>Vui lòng kiểm tra lại thông tin trước khi xác nhận.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@model List<FastFoodEcommerce.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container my-5">
    <h2 class="section-title">Giỏ Hàng Của Bạn</h2>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5">
            <i class="fas fa-shopping-cart fa-4x mb-3 text-muted"></i>
            <h3>Giỏ hàng trống</h3>
            <p>Hãy thêm một vài món ăn ngon vào giỏ nhé!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">Quay lại thực đơn</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 rounded-4 p-3">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Giá</th>
                                    <th>Số lượng</th>
                                    <th>Tổng</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@item.ImageUrl" class="rounded-3 me-3" style="width: 60px; height: 60px; object-fit: cover;">
                                                <span class="fw-bold">@item.ProductName</span>
                                            </div>
                                        </td>
                                        <td>@item.Price.ToString("N0")đ</td>
                                        <td>@item.Quantity</td>
                                        <td class="fw-bold">@item.Total.ToString("N0")đ</td>
                                        <td>
                                            <a asp-action="RemoveFromCart" asp-route-id="@item.ProductId" class="text-danger">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 p-4 mt-4 mt-lg-0">
                    <h4 class="mb-4">Tóm tắt đơn hàng</h4>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Tạm tính</span>
                        <span>@Model.Sum(x => x.Total).ToString("N0")đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Phí vận chuyển</span>
                        <span class="text-success">Miễn phí</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold h5">Tổng cộng</span>
                        <span class="fw-bold h5 text-danger">@Model.Sum(x => x.Total).ToString("N0")đ</span>
                    </div>
                    <a asp-action="Checkout" class="btn btn-primary w-100 py-3">Tiến hành thanh toán</a>
                </div>
            </div>
        </div>
    }
</div>

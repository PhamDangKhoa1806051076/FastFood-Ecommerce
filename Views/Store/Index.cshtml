@model IEnumerable<FastFoodEcommerce.Models.Store>
@{
    ViewData["Title"] = "Hệ thống cửa hàng";
}

<div class="container-fluid px-5 py-5">
    <h2 class="section-title mb-5">Hệ Thống Cửa Hàng</h2>

    <div class="row">
        <div class="col-lg-4">
            <div class="list-group rounded-4 shadow-sm overflow-hidden" id="store-list">
                @foreach (var store in Model)
                {
                    <button type="button" class="list-group-item list-group-item-action p-4 border-0 store-item" 
                            data-map="@store.MapUrl" data-name="@store.Name">
                        <h5 class="fw-bold mb-1 text-danger">@store.Name</h5>
                        <p class="mb-1 small"><i class="fas fa-map-marker-alt me-2"></i>@store.Address</p>
                        <p class="mb-0 small"><i class="fas fa-phone me-2"></i>@store.Phone</p>
                    </button>
                }
            </div>
        </div>
        <div class="col-lg-8 mt-4 mt-lg-0">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100" style="min-height: 500px;">
                <iframe id="map-iframe" 
                        src="@(Model.FirstOrDefault()?.MapUrl)" 
                        width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('.store-item').click(function() {
            var mapUrl = $(this).data('map');
            $('.store-item').removeClass('active bg-light');
            $(this).addClass('active bg-light');
            $('#map-iframe').attr('src', mapUrl);
        });

        // Set first item active
        $('.store-item').first().addClass('active bg-light');
    </script>
}

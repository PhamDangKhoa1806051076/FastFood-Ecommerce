@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = "_Layout";
    var currentCulture = Context.Request.Cookies["FastFoodLanguage"] ?? "vi";
    string T(string key) => FastFoodEcommerce.Helpers.LanguageHelper.Get(key, currentCulture);
}

<div class="container-fluid p-0">
    <div class="row g-0" style="min-height: calc(100vh - 85px);">
        <!-- Cột bên trái: Slogan -->
        <div class="col-lg-6 d-none d-lg-flex bg-danger text-white align-items-center justify-content-center p-5">
            <div class="text-center">
                <h1 class="display-3 fw-bold text-uppercase mb-4 animate__animated animate__fadeIn">
                    @T("Slogan").Split('-')[0] <br> @T("Slogan").Split('-')[1] <br> @T("Slogan").Split('-')[2]
                </h1>
                <i class="fas fa-user-plus fa-5x mt-4"></i>
            </div>
        </div>

        <!-- Cột bên phải: Form Đăng ký -->
        <div class="col-lg-6 d-flex align-items-center justify-content-center p-5 bg-white">
            <div class="w-100" style="max-width: 450px;">
                <h2 class="fw-bold mb-4 text-uppercase">@T("Register")</h2>
                
                <form id="registerForm" asp-action="Register" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">@T("FullName") *</label>
                        <input type="text" name="name" class="form-control border-0 border-bottom rounded-0 px-0 focus-none" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">@T("EmailAddress") *</label>
                        <input type="email" name="email" class="form-control border-0 border-bottom rounded-0 px-0 focus-none" required>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">@T("Password") *</label>
                        <input type="password" name="password" id="regPass" class="form-control border-0 border-bottom rounded-0 px-0 focus-none" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">@T("ConfirmPassword") *</label>
                        <input type="password" name="confirmPassword" id="regConfirm" class="form-control border-0 border-bottom rounded-0 px-0 focus-none" required>
                        <div id="passError" class="text-danger small mt-1 d-none">Mật khẩu không khớp!</div>
                    </div>
                    
                    <button type="submit" id="regBtn" class="btn btn-success w-100 py-3 rounded-pill fw-bold text-uppercase mb-4 shadow-sm">
                        <span class="btn-text">@T("CreateAccount")</span>
                        <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                    </button>
                    
                    <div class="text-center">
                        <p class="small text-muted">@T("Login")? <a asp-action="Login" class="text-dark fw-bold text-decoration-none underline">@T("Login")</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('registerForm').addEventListener('submit', function(e) {
        const pass = document.getElementById('regPass').value;
        const confirm = document.getElementById('regConfirm').value;
        const errorDiv = document.getElementById('passError');

        if (pass !== confirm) {
            e.preventDefault();
            errorDiv.classList.remove('d-none');
            return;
        }

        errorDiv.classList.add('d-none');
        const btn = document.getElementById('regBtn');
        btn.disabled = true;
        btn.querySelector('.btn-text').innerText = 'Đang xử lý...';
        btn.querySelector('.spinner-border').classList.remove('d-none');
    });
</script>

<style>
    .focus-none:focus { box-shadow: none; border-color: #000; }
    .btn-success { background-color: #28a745; border: none; }
    .underline { border-bottom: 2px solid #000; }
</style>

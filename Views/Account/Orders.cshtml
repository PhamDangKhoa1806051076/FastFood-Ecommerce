@model IEnumerable<FastFoodEcommerce.Models.Order>
@{
    ViewData["Title"] = "Lịch sử đơn hàng";
    Layout = "_Layout";
    var currentCulture = Context.Request.Cookies["FastFoodLanguage"] ?? "vi";
    string T(string key) => FastFoodEcommerce.Helpers.LanguageHelper.Get(key, currentCulture);
}

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-md-12">
            <h2 class="fw-bold text-uppercase border-start border-danger border-5 ps-3">@T("TrackOrder")</h2>
            <p class="text-muted">Xem lại các món ngon bạn đã từng đặt tại FastFood.</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-5x text-light mb-4"></i>
            <h4 class="text-muted">Bạn chưa có đơn hàng nào.</h4>
            <a asp-controller="Home" asp-action="Index" class="btn btn-danger rounded-pill px-5 py-3 mt-3 fw-bold">Bắt đầu đặt món ngay</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in Model)
            {
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                        <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                            <div>
                                <span class="small text-muted text-uppercase fw-bold">Mã đơn hàng</span>
                                <h5 class="fw-bold mb-0 text-danger">#@order.Id</h5>
                            </div>
                            <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-2">
                                <i class="fas fa-check-circle me-1"></i> Đã hoàn thành
                            </span>
                        </div>
                        <div class="card-body p-4 pt-0">
                            <hr class="mt-0">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Ngày đặt:</span>
                                <span class="fw-bold">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-4">
                                <span class="text-muted">Tổng thanh toán:</span>
                                <span class="fw-bold fs-5 text-danger">@order.TotalAmount.ToString("N0")đ</span>
                            </div>
                            <div class="d-grid">
                                <button class="btn btn-outline-dark rounded-pill py-2 small fw-bold">Xem chi tiết món ăn</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

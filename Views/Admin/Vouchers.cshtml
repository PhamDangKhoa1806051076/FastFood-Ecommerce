@model IEnumerable<FastFoodEcommerce.Models.Voucher>
@{
    ViewData["Title"] = "Quản lý Voucher";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-0">Hệ thống Voucher</h2>
            <p class="text-muted">Quản lý các mã giảm giá và chương trình khuyến mãi</p>
        </div>
        <a asp-action="CreateVoucher" class="btn btn-danger btn-lg rounded-pill px-4 fw-bold shadow-sm">
            <i class="fas fa-plus me-2"></i>Thêm Voucher mới
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 border-0">Mã Code</th>
                            <th class="py-3 border-0">Giảm giá</th>
                            <th class="py-3 border-0">Mô tả</th>
                            <th class="py-3 border-0">Thời hạn</th>
                            <th class="py-3 border-0">Trạng thái</th>
                            <th class="pe-4 py-3 border-0 text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var isExpired = item.EndDate < DateTime.Now;
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-dark px-3 py-2 fs-6">@item.Code</span>
                                </td>
                                <td>
                                    <span class="text-danger fw-bold fs-5">@item.DiscountPercentage%</span>
                                </td>
                                <td>@item.Description</td>
                                <td>
                                    <small class="text-muted d-block">Từ: @item.StartDate.ToString("dd/MM/yyyy")</small>
                                    <small class="text-muted d-block">Đến: @item.EndDate.ToString("dd/MM/yyyy")</small>
                                </td>
                                <td>
                                    @if (isExpired)
                                    {
                                        <span class="badge bg-secondary">Hết hạn</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Đang hoạt động</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <a asp-action="EditVoucher" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3 me-2">
                                        <i class="fas fa-edit me-1"></i>Sửa
                                    </a>
                                    <button class="btn btn-outline-danger btn-sm rounded-pill px-3" onclick="deleteVoucher(@item.Id, '@item.Code')">
                                        <i class="fas fa-trash-alt me-1"></i>Xóa
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteVoucher(id, code) {
            if (confirm('Bạn có chắc chắn muốn xóa voucher ' + code + '?')) {
                $.post('/Admin/DeleteVoucher', { id: id }, function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                });
            }
        }
    </script>
}

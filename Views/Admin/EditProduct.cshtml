@model FastFoodEcommerce.Models.Product
@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white p-4">
                    <h3 class="mb-0 fw-bold"><i class="fas fa-edit me-2"></i>Chỉnh sửa: @Model.Name</h3>
                </div>
                <div class="card-body p-5">
                    <form asp-action="EditProduct" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="row g-4">
                            <!-- Left Column: Basic Info -->
                            <div class="col-md-6">
                                <h5 class="fw-bold mb-4 border-start border-danger border-4 ps-3 text-uppercase small">Thông tin cơ bản</h5>
                                
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label fw-bold small text-muted">Tên sản phẩm</label>
                                    <input asp-for="Name" class="form-control rounded-3" placeholder="Nhập tên sản phẩm..." />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Price" class="form-label fw-bold small text-muted">Giá bán (VNĐ)</label>
                                    <input asp-for="Price" class="form-control rounded-3" type="number" />
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="CategoryId" class="form-label fw-bold small text-muted">Danh mục</label>
                                    <select asp-for="CategoryId" class="form-select rounded-3" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                                        <option value="">-- Chọn danh mục --</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label fw-bold small text-muted">Mô tả sản phẩm</label>
                                    <textarea asp-for="Description" class="form-control rounded-3" rows="4" placeholder="Mô tả chi tiết về sản phẩm..."></textarea>
                                    <span asp-validation-for="Description" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Right Column: Media & Specs -->
                            <div class="col-md-6">
                                <h5 class="fw-bold mb-4 border-start border-warning border-4 ps-3 text-uppercase small">Hình ảnh & Thông số</h5>

                                <div class="mb-3">
                                    <label asp-for="ImageUrl" class="form-label fw-bold small text-muted">URL hình ảnh chính</label>
                                    <input asp-for="ImageUrl" class="form-control rounded-3" placeholder="https://..." />
                                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="AdditionalImages" class="form-label fw-bold small text-muted">URL hình ảnh phụ (Cách nhau bởi dấu ;)</label>
                                    <input asp-for="AdditionalImages" class="form-control rounded-3" placeholder="url1;url2;url3" />
                                </div>

                                <div class="mb-3">
                                    <label asp-for="StockQuantity" class="form-label fw-bold small text-muted">Số lượng tồn kho</label>
                                    <input asp-for="StockQuantity" class="form-control rounded-3" type="number" />
                                </div>

                                <div class="row g-3">
                                    <div class="col-4">
                                        <label asp-for="Calories" class="form-label fw-bold small text-muted">Calo</label>
                                        <input asp-for="Calories" class="form-control rounded-3" type="number" />
                                    </div>
                                    <div class="col-4">
                                        <label asp-for="Protein" class="form-label fw-bold small text-muted">Protein (g)</label>
                                        <input asp-for="Protein" class="form-control rounded-3" type="number" step="0.1" />
                                    </div>
                                    <div class="col-4">
                                        <label asp-for="Fat" class="form-label fw-bold small text-muted">Béo (g)</label>
                                        <input asp-for="Fat" class="form-control rounded-3" type="number" step="0.1" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-5">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm">
                                <i class="fas fa-save me-2"></i>Lưu thay đổi
                            </button>
                            <a asp-action="Products" class="btn btn-outline-secondary btn-lg rounded-pill px-5 fw-bold">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

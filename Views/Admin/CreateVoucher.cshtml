@model FastFoodEcommerce.Models.Voucher
@{
    ViewData["Title"] = "Thêm Voucher mới";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-danger text-white p-4">
                    <h3 class="mb-0 fw-bold"><i class="fas fa-ticket-alt me-2"></i>Thêm Voucher mới</h3>
                </div>
                <div class="card-body p-5">
                    <form asp-action="CreateVoucher" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Code" class="form-label fw-bold small text-muted text-uppercase">Mã Voucher</label>
                                    <input asp-for="Code" class="form-control rounded-3 fw-bold" placeholder="VD: KM2026" style="text-transform: uppercase;" />
                                    <span asp-validation-for="Code" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="DiscountPercentage" class="form-label fw-bold small text-muted text-uppercase">% Giảm giá</label>
                                    <input asp-for="DiscountPercentage" class="form-control rounded-3" type="number" min="1" max="100" />
                                    <span asp-validation-for="DiscountPercentage" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label fw-bold small text-muted text-uppercase">Mô tả khuyến mãi</label>
                                    <textarea asp-for="Description" class="form-control rounded-3" rows="3" placeholder="VD: Giảm giá 20k cho đơn hàng từ 100k..."></textarea>
                                    <span asp-validation-for="Description" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="StartDate" class="form-label fw-bold small text-muted text-uppercase">Ngày bắt đầu</label>
                                    <input asp-for="StartDate" class="form-control rounded-3" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="EndDate" class="form-label fw-bold small text-muted text-uppercase">Ngày kết thúc</label>
                                    <input asp-for="EndDate" class="form-control rounded-3" type="date" value="@DateTime.Now.AddDays(30).ToString("yyyy-MM-dd")" />
                                    <span asp-validation-for="EndDate" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-5">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold shadow-sm">
                                <i class="fas fa-save me-2"></i>Lưu Voucher
                            </button>
                            <a asp-action="Vouchers" class="btn btn-outline-secondary btn-lg rounded-pill px-5 fw-bold">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

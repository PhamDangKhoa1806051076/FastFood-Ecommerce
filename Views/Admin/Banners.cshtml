@model IEnumerable<FastFoodEcommerce.Models.Banner>
@{
    ViewData["Title"] = "Quản lý Banner";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-uppercase border-start border-danger border-5 ps-3">Quản lý Banner</h1>
            <p class="text-muted">Cấu hình các chương trình khuyến mãi hiển thị ở trang chủ.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">Dashboard</a>
            <a asp-action="CreateBanner" class="btn btn-danger rounded-pill px-4">Thêm Banner mới</a>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var banner in Model)
        {
            <div class="col-md-6 col-lg-4" id="banner-card-@banner.Id">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative">
                    <div class="position-absolute top-0 end-0 p-2 d-flex gap-1" style="z-index: 10;">
                        <a asp-action="EditBanner" asp-route-id="@banner.Id" class="btn btn-sm btn-white bg-white rounded-circle shadow-sm text-primary">
                            <i class="fas fa-edit"></i>
                        </a>
                        <button class="btn btn-sm btn-white bg-white rounded-circle shadow-sm text-danger delete-banner" data-id="@banner.Id">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                    <img src="@banner.ImageUrl" class="card-img-top" style="height: 180px; object-fit: cover;" alt="@banner.Title">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-bold mb-0 text-truncate" style="max-width: 70%;">@banner.Title</h6>
                            <span class="badge @(banner.IsActive ? "bg-success" : "bg-secondary") small">
                                @(banner.IsActive ? "Hiện" : "Ẩn")
                            </span>
                        </div>
                        <p class="text-muted small mb-3 text-truncate-2" style="height: 40px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@banner.SubTitle</p>
                        <div class="d-flex justify-content-between align-items-center mt-3 border-top pt-2">
                            <span class="text-muted small"><i class="fas fa-sort-numeric-down me-1"></i>Thứ tự: @banner.DisplayOrder</span>
                            @if (!string.IsNullOrEmpty(banner.LinkUrl))
                            {
                                <i class="fas fa-link text-muted small" title="@banner.LinkUrl"></i>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-images fa-4x text-light mb-3"></i>
                <p class="text-muted">Chưa có banner nào. Hãy tạo cái đầu tiên!</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.delete-banner').click(function() {
                if (confirm('Bạn có chắc chắn muốn xóa Banner này không?')) {
                    const id = $(this).data('id');
                    const card = $(`#banner-card-${id}`);
                    
                    $.post('/Admin/DeleteBanner', { id: id }, function(response) {
                        if (response.success) {
                            card.fadeOut(400, function() { $(this).remove(); });
                        } else {
                            alert('Lỗi: ' + response.message);
                        }
                    });
                }
            });
        });
    </script>
}

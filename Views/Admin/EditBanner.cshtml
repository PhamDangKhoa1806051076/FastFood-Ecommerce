@model FastFoodEcommerce.Models.Banner
@{
    ViewData["Title"] = "Chỉnh sửa Banner";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-5 d-none d-md-block bg-light d-flex align-items-center justify-content-center border-end">
                        <div class="p-4 text-center">
                            <h6 class="fw-bold text-uppercase text-muted mb-3 small">Xem trước ảnh</h6>
                            <img id="previewImage" src="@Model.ImageUrl" class="img-fluid rounded-4 shadow-sm" style="max-height: 300px; object-fit: cover;" onerror="this.src='https://placehold.co/600x400?text=No+Image'">
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="card-body p-5">
                            <h2 class="fw-bold mb-4"><i class="fas fa-edit text-primary me-2"></i>Chỉnh sửa Banner</h2>
                            <form asp-action="EditBanner" method="post">
                                <input type="hidden" asp-for="Id" />
                                <input type="hidden" asp-for="CreatedAt" />

                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-uppercase">Tiêu đề</label>
                                    <input asp-for="Title" class="form-control rounded-3" placeholder="Ví dụ: Giảm giá 50%">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-uppercase">Mô tả phụ</label>
                                    <input asp-for="SubTitle" class="form-control rounded-3" placeholder="Ví dụ: Áp dụng cho combo gà">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-uppercase">Link ảnh (URL)</label>
                                    <input asp-for="ImageUrl" id="imageUrlInput" class="form-control rounded-3" placeholder="https://images.unsplash.com/..." required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-uppercase">Link đích khi click</label>
                                    <input asp-for="LinkUrl" class="form-control rounded-3" placeholder="/Home/Index#menu">
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold small text-uppercase">Thứ tự hiển thị</label>
                                        <input asp-for="DisplayOrder" type="number" class="form-control rounded-3">
                                        <div class="form-text small">
                                            <0: Top Bar | 0-99: Carousel | >=100: Bottom
                                        </div>
                                    </div>
                                    <div class="col-md-6 mb-3 d-flex align-items-center pt-4">
                                        <div class="form-check form-switch">
                                            <input asp-for="IsActive" class="form-check-input" type="checkbox">
                                            <label class="form-check-label fw-bold small text-uppercase">Đang hoạt động</label>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="d-grid gap-2 mt-4">
                                    <button type="submit" class="btn btn-primary py-3 rounded-pill fw-bold">Cập nhật thay đổi</button>
                                    <a asp-action="Banners" class="btn btn-link text-dark text-decoration-none text-center small">Hủy và quay lại</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#imageUrlInput').on('input', function() {
                $('#previewImage').attr('src', $(this).val());
            });
        });
    </script>
}

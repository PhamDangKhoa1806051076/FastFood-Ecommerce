@model IEnumerable<FastFoodEcommerce.Models.Order>
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-md-12">
            <h1 class="fw-bold text-uppercase border-start border-danger border-5 ps-3">Hệ thống Quản trị</h1>
            <p class="text-muted">Chào mừng trở lại, Quản trị viên.</p>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold">Tổng doanh thu</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalRevenue.ToString("N0")đ</h3>
                    </div>
                    <i class="fas fa-money-bill-wave fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-danger text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold">Doanh thu hôm nay</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.TodayRevenue.ToString("N0")đ</h3>
                        <small>@ViewBag.TodayOrders đơn mới</small>
                    </div>
                    <i class="fas fa-chart-line fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-warning text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold">Đơn đang chờ</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.PendingOrders</h3>
                    </div>
                    <i class="fas fa-clock fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-success text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold">Sản phẩm</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.ProductCount</h3>
                    </div>
                    <i class="fas fa-box fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Quick Actions -->
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Thao tác nhanh</h5>
                    <div class="d-grid gap-2">
                        <a asp-action="Products" class="btn btn-outline-dark py-3 rounded-pill fw-bold text-start ps-4">
                            <i class="fas fa-box me-2"></i> Quản lý sản phẩm
                        </a>
                        <a asp-action="Inventory" class="btn btn-outline-dark py-3 rounded-pill fw-bold text-start ps-4">
                            <i class="fas fa-warehouse me-2"></i> Quản lý kho hàng
                        </a>
                        <a asp-action="Orders" class="btn btn-outline-dark py-3 rounded-pill fw-bold text-start ps-4">
                            <i class="fas fa-file-invoice me-2"></i> Quản lý đơn hàng
                        </a>
                        <a asp-action="Banners" class="btn btn-outline-dark py-3 rounded-pill fw-bold text-start ps-4">
                            <i class="fas fa-images me-2"></i> Quản lý Banner
                        </a>
                        <a asp-action="Vouchers" class="btn btn-outline-dark py-3 rounded-pill fw-bold text-start ps-4">
                            <i class="fas fa-ticket-alt me-2"></i> Quản lý Voucher
                        </a>
                        <a asp-action="AuditLogs" class="btn btn-outline-dark py-3 rounded-pill fw-bold text-start ps-4">
                            <i class="fas fa-history me-2"></i> Nhật ký hoạt động
                        </a>
                        <hr>
                        <a asp-action="ExportSalesToExcel" class="btn btn-success py-3 rounded-pill fw-bold">
                            <i class="fas fa-file-excel me-2"></i> Xuất báo cáo Excel
                        </a>
                    </div>

                    <h5 class="fw-bold mt-5 mb-4">Top bán chạy</h5>
                    <ul class="list-group list-group-flush">
                        @foreach (var item in ViewBag.TopProducts)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="text-truncate" style="max-width: 180px;">@item.Name</span>
                                <span class="badge bg-danger rounded-pill">@item.Count</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Charts & Recent Orders -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Doanh thu 7 ngày qua</h5>
                    <canvas id="revenueChart" height="200"></canvas>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Đơn hàng gần đây</h5>
                        <a asp-action="Orders" class="text-danger fw-bold text-decoration-none small">Xem tất cả</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã</th>
                                    <th>Khách hàng</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model)
                                {
                                    <tr>
                                        <td>#@order.Id</td>
                                        <td>@order.CustomerName</td>
                                        <td>@order.OrderDate.ToString("dd/MM HH:mm")</td>
                                        <td class="fw-bold">@order.TotalAmount.ToString("N0")đ</td>
                                        <td>
                                            <span class="badge @(order.Status == "Completed" ? "bg-success" : "bg-warning")">@order.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart').getContext('2d');
        const revenueChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                    borderColor: '#dc3545',
                    backgroundColor: 'rgba(220, 53, 69, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { 
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return value.toLocaleString() + 'đ';
                            }
                        }
                    }
                }
            }
        });
    </script>
}

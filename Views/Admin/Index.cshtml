@model IEnumerable<FastFoodEcommerce.Models.Order>
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-md-12">
            <h1 class="fw-bold text-uppercase border-start border-danger border-5 ps-3">Hệ thống Quản trị</h1>
            <p class="text-muted">Chào mừng trở lại, Quản trị viên.</p>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold">Tổng doanh thu</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalRevenue.ToString("N0")đ</h3>
                    </div>
                    <i class="fas fa-money-bill-wave fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-success text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold">Đơn hàng</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.OrderCount</h3>
                    </div>
                    <i class="fas fa-shopping-cart fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-info text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold">Sản phẩm</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.ProductCount</h3>
                    </div>
                    <i class="fas fa-hamburger fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-warning text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold">Vouchers</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.VoucherCount</h3>
                    </div>
                    <i class="fas fa-ticket-alt fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Quick Actions -->
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Thao tác nhanh</h5>
                    <div class="d-grid gap-2">
                        <a asp-action="Products" class="btn btn-outline-dark py-3 rounded-pill fw-bold">
                            <i class="fas fa-box me-2"></i> Quản lý sản phẩm
                        </a>
                        <a asp-action="Orders" class="btn btn-outline-dark py-3 rounded-pill fw-bold">
                            <i class="fas fa-file-invoice me-2"></i> Quản lý đơn hàng
                        </a>
                        <a asp-action="CreateProduct" class="btn btn-danger py-3 rounded-pill fw-bold">
                            <i class="fas fa-plus me-2"></i> Thêm sản phẩm mới
                        </a>
                    </div>

                    <h5 class="fw-bold mt-5 mb-4">Sản phẩm bán chạy</h5>
                    <ul class="list-group list-group-flush">
                        @foreach (var item in ViewBag.TopProducts)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                @item.Name
                                <span class="badge bg-danger rounded-pill">@item.Count</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Charts & Recent Orders -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Xu hướng bán hàng (Biểu đồ mẫu)</h5>
                    <canvas id="revenueChart" height="200"></canvas>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Đơn hàng gần đây</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Khách hàng</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model)
                                {
                                    <tr>
                                        <td>#@order.Id</td>
                                        <td>@order.CustomerName</td>
                                        <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                        <td class="fw-bold">@order.TotalAmount.ToString("N0")đ</td>
                                        <td>
                                            <span class="badge @(order.Status == "Completed" ? "bg-success" : "bg-warning")">@order.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart').getContext('2d');
        const revenueChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: [1200000, 1900000, 1500000, 2500000, 2200000, 3000000, 2800000],
                    borderColor: '#dc3545',
                    backgroundColor: 'rgba(220, 53, 69, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    </script>
}

@model IEnumerable<FastFoodEcommerce.Models.AuditLog>
@{
    ViewData["Title"] = "Nhật ký Hoạt động";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-uppercase border-start border-danger border-5 ps-3">Nhật ký Hoạt động</h1>
            <p class="text-muted">Theo dõi lịch sử thao tác của các quản trị viên.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">Dashboard</a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Thời gian</th>
                            <th>Quản trị viên</th>
                            <th>Hành động</th>
                            <th>Chi tiết</th>
                            <th>IP Address</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td class="text-muted small">@log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td class="fw-bold">@log.AdminEmail</td>
                                <td>
                                    <span class="badge @(log.Action.Contains("Thêm") ? "bg-success" : log.Action.Contains("Cập nhật") ? "bg-info" : "bg-secondary")">
                                        @log.Action
                                    </span>
                                </td>
                                <td class="small">@log.Details</td>
                                <td class="text-muted small">@log.IpAddress</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

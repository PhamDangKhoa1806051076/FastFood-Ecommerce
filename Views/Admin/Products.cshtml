@model IEnumerable<FastFoodEcommerce.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold text-uppercase mb-0">Quản lý sản phẩm</h2>
        <a asp-action="CreateProduct" class="btn btn-danger rounded-pill px-4 fw-bold">
            <i class="fas fa-plus me-2"></i> Thêm sản phẩm
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <img src="@p.ImageUrl" alt="@p.Name" class="rounded-3" style="width: 60px; height: 60px; object-fit: cover;">
                            </td>
                            <td class="fw-bold">@p.Name</td>
                            <td><span class="badge bg-light text-dark border">@p.Category?.Name</span></td>
                            <td class="text-danger fw-bold">@p.Price.ToString("N0")đ</td>
                            <td class="text-end pe-4">
                                <a asp-action="EditProduct" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1">
                                    <i class="fas fa-edit me-1"></i>Sửa
                                </a>
                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="deleteProduct(@p.Id, '@p.Name')">
                                    <i class="fas fa-trash me-1"></i>Xóa
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteProduct(id, name) {
            if (confirm('Bạn có chắc chắn muốn xóa sản phẩm "' + name + '"?')) {
                $.post('/Admin/DeleteProduct', { id: id }, function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                });
            }
        }
    </script>
}

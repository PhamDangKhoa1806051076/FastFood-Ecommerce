@model IEnumerable<FastFoodEcommerce.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Section -->
<section class="hero-section text-center">
    <div class="container">
        <h1 class="hero-title animate__animated animate__fadeInDown">Ngon Khó Cưỡng, Giao Tận Nơi!</h1>
        <p class="hero-subtitle animate__animated animate__fadeInUp">Khám phá thực đơn đa dạng từ Burger, Pizza đến các món ăn kèm hấp dẫn.</p>
        <a href="#menu" class="btn btn-primary btn-lg">Xem thực đơn ngay</a>
    </div>
</section>

<!-- Menu Section -->
<div class="container" id="menu">
    <div class="text-center mb-5">
        <h2 class="section-title">Thực Đơn Nổi Bật</h2>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="product-card">
                    <div class="product-img-wrapper">
                        <img src="@item.ImageUrl" class="product-img" alt="@item.Name">
                    </div>
                    <div class="product-body">
                        <span class="product-category">@item.Category?.Name</span>
                        <h3 class="product-title">@item.Name</h3>
                        <p class="product-description">@item.Description</p>
                    </div>
                    <div class="product-footer">
                        <span class="product-price">@item.Price.ToString("N0")đ</span>
                        <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id" class="btn-add-cart" title="Thêm vào giỏ hàng">
                            <i class="fas fa-plus"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@model IEnumerable<FastFoodEcommerce.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
    var categories = ViewBag.Categories as IEnumerable<FastFoodEcommerce.Models.Category>;
    var currentCulture = Context.Request.Cookies["FastFoodLanguage"] ?? "vi";
    string T(string key) => FastFoodEcommerce.Helpers.LanguageHelper.Get(key, currentCulture);
}

<!-- Dynamic Banner Carousel -->
@if (ViewBag.Banners != null && ((IEnumerable<FastFoodEcommerce.Models.Banner>)ViewBag.Banners).Any())
{
    <div id="homeCarousel" class="carousel slide shadow-sm" data-bs-ride="carousel" data-bs-interval="3000">
        <div class="carousel-indicators">
            @{ var bi = 0; }
            @foreach (var banner in ViewBag.Banners)
            {
                <button type="button" data-bs-target="#homeCarousel" data-bs-slide-to="@bi" class="@(bi == 0 ? "active" : "")"></button>
                bi++;
            }
        </div>
        <div class="carousel-inner">
            @{ var first = true; }
            @foreach (var banner in ViewBag.Banners)
            {
                <div class="carousel-item @(first ? "active" : "")">
                    <img src="@banner.ImageUrl" class="d-block w-100" style="height: 450px; object-fit: cover;" alt="@banner.Title">
                    <div class="carousel-caption d-none d-md-block text-start bg-dark bg-opacity-25 p-4 rounded-4" style="bottom: 10%; left: 10%;">
                        <h2 class="display-4 fw-bold">@banner.Title</h2>
                        <p class="fs-4">@banner.SubTitle</p>
                        @if (!string.IsNullOrEmpty(banner.LinkUrl))
                        {
                            <a href="@banner.LinkUrl" class="btn btn-danger btn-lg rounded-pill px-5">Xem ngay</a>
                        }
                    </div>
                </div>
                first = false;
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#homeCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#homeCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
        </button>
    </div>
}
else
{
    <!-- Default Hero Section -->
    <section class="hero-section text-center py-5 mb-0" style="background: #f8f9fa;">
        <div class="container-fluid px-5">
            <div class="row align-items-center">
                <div class="col-lg-6 text-start">
                    <h1 class="display-2 fw-bold text-dark mb-4 animate__animated animate__fadeInLeft">@T("Slogan").Split('-')[0], <br><span class="text-danger">@T("Slogan").Split('-')[1]!</span></h1>
                    <p class="lead text-muted mb-5 fs-4">@T("Slogan")</p>
                    <div class="d-flex gap-3">
                        <a href="#menu-section" class="btn btn-danger btn-lg px-5 rounded-pill fw-bold py-3 shadow">@T("OrderNow")</a>
                        <a href="#" class="btn btn-outline-dark btn-lg px-5 rounded-pill fw-bold py-3">@T("FindStore")</a>
                    </div>
                </div>
                <div class="col-lg-6 animate__animated animate__fadeInRight">
                    <img src="https://images.unsplash.com/photo-1594212699903-ec8a3eca50f5?q=80&w=1200" class="img-fluid rounded-5 shadow-lg" alt="Fast Food Hero">
                </div>
            </div>
        </div>
    </section>
}

<!-- Menu Category Tabs (KFC Style) -->
<div id="menu-section" class="bg-white sticky-top shadow-sm py-2" style="top: 85px; z-index: 1020;">
    <div class="container-fluid px-5">
        <ul class="nav nav-tabs border-0 flex-nowrap overflow-auto text-uppercase fw-bold" id="categoryTabs" role="tablist" style="scrollbar-width: none;">
            <li class="nav-item me-2" role="presentation">
                <button class="nav-link active border-0 py-3 px-4 text-dark category-btn" data-category-id="0">@T("AllProducts")</button>
            </li>
            @if (categories != null)
            {
                foreach (var cat in categories)
                {
                    <li class="nav-item me-2" role="presentation">
                        <button class="nav-link border-0 py-3 px-4 text-dark category-btn" data-category-id="@cat.Id">@cat.Name</button>
                    </li>
                }
            }
        </ul>
    </div>
</div>

<!-- Product List Area -->
<div class="container-fluid px-5 py-5">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <h2 class="fw-bold fs-1" id="current-category-name">@T("AllProducts")</h2>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-dark rounded-pill px-4" type="button" data-bs-toggle="offcanvas" data-bs-target="#filterSidebar">
                <i class="fas fa-filter me-2"></i>Bộ lọc
            </button>
            <div class="dropdown">
                <button class="btn btn-outline-secondary rounded-pill px-4 dropdown-toggle" type="button" data-bs-toggle="dropdown" id="sort-label">
                    Sắp xếp: Mới nhất
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item sort-option" data-sort="newest" href="#">Mới nhất</a></li>
                    <li><a class="dropdown-item sort-option" data-sort="price_asc" href="#">Giá: Thấp đến Cao</a></li>
                    <li><a class="dropdown-item sort-option" data-sort="price_desc" href="#">Giá: Cao đến Thấp</a></li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Filter Offcanvas -->
    <div class="offcanvas offcanvas-end rounded-start-4" tabindex="-1" id="filterSidebar" aria-labelledby="filterSidebarLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-bold" id="filterSidebarLabel">Bộ lọc món ăn</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-4">
            <!-- Price Range -->
            <div class="mb-5">
                <label class="form-label fw-bold mb-3 text-uppercase small text-muted">Khoảng giá (VNĐ)</label>
                <div class="d-flex align-items-center gap-2">
                    <input type="number" id="minPrice" class="form-control rounded-3" placeholder="Từ" step="1000">
                    <span>-</span>
                    <input type="number" id="maxPrice" class="form-control rounded-3" placeholder="Đến" step="1000">
                </div>
            </div>

            <!-- Rating -->
            <div class="mb-5">
                <label class="form-label fw-bold mb-3 text-uppercase small text-muted">Đánh giá tối thiểu</label>
                <div class="d-flex flex-column gap-2">
                    @for (int i = 5; i >= 1; i--)
                    {
                        <div class="form-check custom-rating-check">
                            <input class="form-check-input rating-filter" type="radio" name="minRating" id="rating-@i" value="@i">
                            <label class="form-check-label text-warning" for="rating-@i">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <i class="@(s <= i ? "fas" : "far") fa-star"></i>
                                }
                                <span class="text-dark ms-2 small fw-bold">(@i sao trở lên)</span>
                            </label>
                        </div>
                    }
                    <div class="form-check custom-rating-check">
                        <input class="form-check-input rating-filter" type="radio" name="minRating" id="rating-0" value="0" checked>
                        <label class="form-check-label text-muted" for="rating-0">Tất cả đánh giá</label>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-2 mt-auto">
                <button class="btn btn-danger py-3 rounded-pill fw-bold shadow" id="apply-filters" data-bs-dismiss="offcanvas">Áp dụng bộ lọc</button>
                <button class="btn btn-link text-dark text-decoration-none" id="reset-filters">Xóa tất cả bộ lọc</button>
            </div>
        </div>
    </div>

    <div id="product-list-container" class="animate__animated animate__fadeIn">
        @await Html.PartialAsync("_ProductList", Model)
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let currentCategoryId = 0;
            let currentSort = "newest";

            function loadProducts() {
                let minPrice = $('#minPrice').val();
                let maxPrice = $('#maxPrice').val();
                let minRating = $('input[name="minRating"]:checked').val();

                $('#product-list-container').fadeOut(200, function () {
                    $.ajax({
                        url: '/Home/GetProductsByCategory',
                        data: { 
                            categoryId: currentCategoryId,
                            minPrice: minPrice,
                            maxPrice: maxPrice,
                            minRating: minRating,
                            sort: currentSort
                        },
                        success: function (data) {
                            $('#product-list-container').html(data).fadeIn(300);
                        },
                        error: function () {
                            alert('Có lỗi xảy ra khi tải dữ liệu.');
                        }
                    });
                });
            }

            // Category Tab Click
            $('.category-btn').click(function () {
                currentCategoryId = $(this).data('category-id');
                $('.category-btn').removeClass('active');
                $(this).addClass('active');
                $('#current-category-name').text($(this).text());
                loadProducts();
            });

            // Filter Apply
            $('#apply-filters').click(function() {
                loadProducts();
            });

            // Filter Reset
            $('#reset-filters').click(function() {
                $('#minPrice').val('');
                $('#maxPrice').val('');
                $('#rating-0').prop('checked', true);
                loadProducts();
            });

            // Sort Click
            $('.sort-option').click(function(e) {
                e.preventDefault();
                currentSort = $(this).data('sort');
                $('#sort-label').text('Sắp xếp: ' + $(this).text());
                loadProducts();
            });

            // Hero Smooth Scroll
            $('#menu-link').click(function(e) {
                e.preventDefault();
                $('html, body').animate({
                    scrollTop: $("#menu-section").offset().top - 80
                }, 800);
            });
        });
    </script>
}

<style>
    .nav-tabs .nav-link {
        border-radius: 0;
        position: relative;
        transition: all 0.2s;
        white-space: nowrap;
    }
    .nav-tabs .nav-link.active {
        color: #e63946 !important;
        background: transparent !important;
    }
    .nav-tabs .nav-link.active:after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: #e63946;
    }
    .nav-tabs .nav-link:hover {
        color: #e63946 !important;
    }
    #categoryTabs::-webkit-scrollbar {
        display: none;
    }
</style>

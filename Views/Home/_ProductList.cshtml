@model IEnumerable<FastFoodEcommerce.Models.Product>
@{
    var currentCulture = Context.Request.Cookies["FastFoodLanguage"] ?? "vi";
    string T(string key) => FastFoodEcommerce.Helpers.LanguageHelper.Get(key, currentCulture);
}

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4 col-xl-3">
            <div class="product-card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="product-img-wrapper position-relative">
                    <img src="@item.ImageUrl" class="product-img w-100" style="height: 250px; object-fit: cover;" alt="@item.Name" loading="lazy">
                    <div class="position-absolute top-0 end-0 p-2">
                        <span class="badge bg-white text-danger fw-bold rounded-circle p-2 shadow-sm">
                            <i class="far fa-heart"></i>
                        </span>
                    </div>
                </div>
                <div class="product-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h4 class="product-title fw-bold mb-0">@item.Name</h4>
                        <span class="fw-bold text-danger fs-5">@item.Price.ToString("N0")đ</span>
                    </div>
                    <div class="mb-2 text-warning small">
                        @{
                            var avgRating = item.Reviews != null && item.Reviews.Any() ? item.Reviews.Average(r => r.Rating) : 0;
                            var roundedRating = (int)Math.Round(avgRating);
                        }
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="@(i <= roundedRating ? "fas" : "far") fa-star"></i>
                        }
                        <span class="text-muted ms-1">(@avgRating.ToString("F1"))</span>
                    </div>
                    <p class="product-description text-muted small mb-3">@item.Description</p>
                    <div class="d-flex gap-2">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-dark w-50 rounded-pill py-2 fw-bold small">
                            @T("Details")
                        </a>
                        <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id" class="btn btn-danger w-50 rounded-pill py-2 fw-bold small">
                            @T("AddToCart")
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

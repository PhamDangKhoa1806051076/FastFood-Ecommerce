@model IEnumerable<FastFoodEcommerce.Models.Voucher>
@{
    ViewData["Title"] = "Khuyến mãi";
    var currentCulture = Context.Request.Cookies["FastFoodLanguage"] ?? "vi";
    string T(string key) => FastFoodEcommerce.Helpers.LanguageHelper.Get(key, currentCulture);
}

<div class="container py-5">
    <h2 class="section-title text-center mb-5">@T("Promotion")</h2>
    
    <div class="row g-4">
        @foreach (var v in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden voucher-card">
                    <div class="card-body p-4 d-flex">
                        <div class="discount-badge bg-danger text-white d-flex align-items-center justify-content-center flex-column rounded-3 p-3 me-3" style="min-width: 80px;">
                            <span class="fs-3 fw-bold">@v.DiscountPercentage%</span>
                            <span class="small">OFF</span>
                        </div>
                        <div class="flex-grow-1">
                            <h5 class="fw-bold mb-1">@T("VoucherCode"): <span class="text-danger">@v.Code</span></h5>
                            <p class="text-muted small mb-2">@v.Description</p>
                            <div class="d-flex align-items-center text-secondary small">
                                <i class="far fa-clock me-1"></i>
                                <span>@T("Expired"): @v.EndDate.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-0 p-3 text-center">
                        @if (v.IsActive)
                        {
                            <button class="btn btn-dark btn-sm rounded-pill px-4 copy-btn" data-code="@v.Code">@T("CopyCode")</button>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@T("Expired")</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .voucher-card {
        transition: transform 0.3s ease;
    }
    .voucher-card:hover {
        transform: translateY(-5px);
    }
    .discount-badge {
        box-shadow: 0 4px 10px rgba(230, 57, 70, 0.2);
    }
</style>

@section Scripts {
    <script>
        $('.copy-btn').click(function() {
            var code = $(this).data('code');
            navigator.clipboard.writeText(code);
            $(this).text('Đã sao chép!').removeClass('btn-dark').addClass('btn-success');
            setTimeout(() => {
                $(this).text('Sao chép mã').removeClass('btn-success').addClass('btn-dark');
            }, 2000);
        });
    </script>
}

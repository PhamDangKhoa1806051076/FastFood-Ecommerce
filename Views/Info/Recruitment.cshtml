@{
    ViewData["Title"] = "Tuyển dụng";
}

<div class="position-relative overflow-hidden bg-dark text-white py-5 mb-5 rounded-bottom-5">
    <div class="position-absolute top-0 start-0 w-100 h-100" style="opacity: 0.3;">
        <img src="/recruitment_hero_1778037856869.png" class="w-100 h-100" style="object-fit: cover;">
    </div>
    <div class="container position-relative py-5">
        <div class="row">
            <div class="col-lg-7 py-5 animate__animated animate__fadeInLeft">
                <span class="badge bg-danger mb-3 px-3 py-2 rounded-pill">Gia nhập đội ngũ</span>
                <h1 class="display-3 fw-bold mb-4">Cùng Chúng Tôi <br><span class="text-danger">Lan Tỏa Niềm Vui</span></h1>
                <p class="lead mb-5 text-white-50">FastFood Store không chỉ là nơi làm việc, mà là nơi bạn bắt đầu hành trình phát triển sự nghiệp trong môi trường năng động và chuyên nghiệp nhất.</p>
                <a href="#positions" class="btn btn-danger btn-lg px-5 rounded-pill fw-bold py-3 shadow">Xem các vị trí đang tuyển</a>
            </div>
        </div>
    </div>
</div>

<div class="container py-5" id="positions">
    <div class="row text-center mb-5">
        <div class="col-lg-8 mx-auto">
            <h2 class="fw-bold display-6">Vị trí đang <span class="text-danger">Tìm kiếm</span></h2>
            <p class="text-muted">Hãy chọn vị trí phù hợp nhất với đam mê của bạn.</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Position 1 -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 p-4 hover-shadow transition">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="bg-danger-subtle text-danger p-3 rounded-4">
                        <i class="fas fa-utensils fa-lg"></i>
                    </div>
                    <span class="badge bg-success-subtle text-success">Toàn thời gian</span>
                </div>
                <h4 class="fw-bold mb-2">Nhân viên Phục vụ</h4>
                <p class="text-muted small mb-4">Chào đón và phục vụ khách hàng tại quầy và khu vực bàn ăn với tinh thần niềm nở nhất.</p>
                <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                    <span class="fw-bold text-dark">5-7tr / tháng</span>
                    <a href="#" class="btn btn-outline-danger rounded-pill btn-sm px-3">Ứng tuyển</a>
                </div>
            </div>
        </div>

        <!-- Position 2 -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 p-4 hover-shadow transition">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="bg-primary-subtle text-primary p-3 rounded-4">
                        <i class="fas fa-hat-chef fa-lg"></i>
                    </div>
                    <span class="badge bg-success-subtle text-success">Toàn thời gian</span>
                </div>
                <h4 class="fw-bold mb-2">Nhân viên Bếp</h4>
                <p class="text-muted small mb-4">Chế biến các món ăn theo tiêu chuẩn chất lượng cao nhất của hệ thống FastFood Store.</p>
                <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                    <span class="fw-bold text-dark">6-9tr / tháng</span>
                    <a href="#" class="btn btn-outline-danger rounded-pill btn-sm px-3">Ứng tuyển</a>
                </div>
            </div>
        </div>

        <!-- Position 3 -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 p-4 hover-shadow transition">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="bg-warning-subtle text-warning p-3 rounded-4">
                        <i class="fas fa-shipping-fast fa-lg"></i>
                    </div>
                    <span class="badge bg-info-subtle text-info">Bán thời gian</span>
                </div>
                <h4 class="fw-bold mb-2">Nhân viên Giao hàng</h4>
                <p class="text-muted small mb-4">Giao những bữa ăn nóng hổi đến tận tay khách hàng trong khu vực nội thành.</p>
                <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                    <span class="fw-bold text-dark">25k - 40k / giờ</span>
                    <a href="#" class="btn btn-outline-danger rounded-pill btn-sm px-3">Ứng tuyển</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-light py-5 mt-5">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h2 class="fw-bold display-6 mb-4">Quyền lợi <span class="text-danger">Tuyệt vời</span></h2>
                <ul class="list-unstyled">
                    <li class="mb-3 d-flex align-items-center">
                        <i class="fas fa-check-circle text-success me-3 fs-5"></i>
                        <span>Bảo hiểm sức khỏe và các chế độ theo luật lao động.</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center">
                        <i class="fas fa-check-circle text-success me-3 fs-5"></i>
                        <span>Bữa ăn miễn phí trong ca làm việc.</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center">
                        <i class="fas fa-check-circle text-success me-3 fs-5"></i>
                        <span>Cơ hội thăng tiến lên quản lý sau 6-12 tháng.</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center">
                        <i class="fas fa-check-circle text-success me-3 fs-5"></i>
                        <span>Môi trường làm việc trẻ trung, hòa đồng.</span>
                    </li>
                </ul>
            </div>
            <div class="col-lg-6">
                <div class="card border-0 shadow rounded-4 p-5">
                    <h4 class="fw-bold mb-4">Gửi thông tin nhanh</h4>
                    <form>
                        <div class="mb-3">
                            <input type="text" class="form-control py-3" placeholder="Họ và tên">
                        </div>
                        <div class="mb-3">
                            <input type="email" class="form-control py-3" placeholder="Email liên hệ">
                        </div>
                        <div class="mb-3">
                            <select class="form-select py-3">
                                <option selected>Chọn vị trí ứng tuyển</option>
                                <option>Nhân viên Phục vụ</option>
                                <option>Nhân viên Bếp</option>
                                <option>Nhân viên Giao hàng</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-danger w-100 py-3 rounded-pill fw-bold">Gửi hồ sơ ngay</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-danger-subtle { background-color: #ffe5e7; }
    .bg-primary-subtle { background-color: #e7f5ff; }
    .bg-warning-subtle { background-color: #fff9db; }
    .bg-success-subtle { background-color: #d3f9d8; }
    .bg-info-subtle { background-color: #e3fafc; }
    .hover-shadow:hover { box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important; }
    .transition { transition: all 0.3s; }
</style>

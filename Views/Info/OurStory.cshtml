@{
    ViewData["Title"] = "Câu chuyện của chúng tôi";
}

<section class="py-5 bg-white">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h6 class="text-danger fw-bold text-uppercase mb-3">Về FastFood</h6>
                <h1 class="display-3 fw-bold mb-4">Câu Chuyện <br><span class="text-danger">Khởi Nguồn</span></h1>
                <p class="lead text-muted mb-4">Hành trình của FastFood Store không bắt đầu từ những bảng quảng cáo rực rỡ, mà từ căn bếp nhỏ với niềm đam mê mang hương vị tuyệt vời nhất đến cho mọi người.</p>
                <div class="border-start border-4 border-danger ps-4 mb-4">
                    <p class="fst-italic text-dark fs-5">"Chúng tôi không chỉ bán thức ăn nhanh, chúng tôi mang đến những khoảnh khắc hạnh phúc trọn vẹn cho gia đình bạn."</p>
                </div>
                <p class="text-muted">Từ năm 2010, chúng tôi đã không ngừng tìm kiếm những nguồn nguyên liệu tươi ngon nhất, những công thức bí truyền để tạo nên những chiếc Burger giòn tan và những lát Pizza đậm đà. Mỗi món ăn tại FastFood đều là một lời cam kết về chất lượng và sự tận tâm.</p>
            </div>
            <div class="col-lg-6">
                <div class="position-relative">
                    <img src="/our_story_hero_1778037842037.png" class="img-fluid rounded-5 shadow-lg" alt="Our Story">
                    <div class="position-absolute bottom-0 start-0 bg-danger text-white p-4 rounded-4 m-4 d-none d-md-block shadow">
                        <h4 class="fw-bold mb-0">14+ Năm</h4>
                        <p class="small mb-0 text-white-50">Phục vụ khách hàng</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container py-5">
        <div class="row text-center mb-5">
            <div class="col-lg-8 mx-auto">
                <h2 class="fw-bold display-5">Giá trị <span class="text-danger">Cốt lõi</span></h2>
                <p class="text-muted">Những điều làm nên sự khác biệt của FastFood Store qua nhiều năm.</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 p-4 text-center hover-translate">
                    <div class="icon-circle bg-danger-subtle text-danger mx-auto mb-4">
                        <i class="fas fa-leaf fa-2x"></i>
                    </div>
                    <h4 class="fw-bold">Nguyên liệu Tươi</h4>
                    <p class="text-muted small">Chúng tôi chỉ sử dụng nguyên liệu tươi ngon nhất, được nhập mới mỗi ngày từ các trang trại uy tín.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 p-4 text-center hover-translate">
                    <div class="icon-circle bg-warning-subtle text-warning mx-auto mb-4">
                        <i class="fas fa-heart fa-2x"></i>
                    </div>
                    <h4 class="fw-bold">Tận Tâm</h4>
                    <p class="text-muted small">Mỗi món ăn được chế biến bằng cả trái tim, đảm bảo hương vị và sự hài lòng tuyệt đối của khách hàng.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 p-4 text-center hover-translate">
                    <div class="icon-circle bg-primary-subtle text-primary mx-auto mb-4">
                        <i class="fas fa-rocket fa-2x"></i>
                    </div>
                    <h4 class="fw-bold">Tốc Độ</h4>
                    <p class="text-muted small">Quy trình chuẩn hóa giúp chúng tôi phục vụ nhanh nhất mà không đánh đổi chất lượng món ăn.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .icon-circle {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }
    .bg-danger-subtle { background-color: #ffe5e7; }
    .bg-warning-subtle { background-color: #fff9db; }
    .bg-primary-subtle { background-color: #e7f5ff; }
    .hover-translate { transition: transform 0.3s; }
    .hover-translate:hover { transform: translateY(-10px); }
</style>

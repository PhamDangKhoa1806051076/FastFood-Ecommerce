@{
    ViewData["Title"] = "Câu chuyện của chúng tôi";
    Layout = "_Layout";
}

<!-- Hero Section -->
<section class="py-0 bg-white">
    <div class="container-fluid px-0">
        <div class="row g-0 align-items-stretch" style="min-height: 90vh; max-height: 90vh; overflow: hidden;">
            <!-- Left Content -->
            <div class="col-lg-6 d-flex align-items-center">
                <div class="p-5 p-lg-5 ms-lg-5">
                    <h6 class="text-danger fw-bold text-uppercase mb-3 letter-spacing">Về FastFood Store</h6>
                    <h1 class="display-3 fw-bold mb-4 lh-1">Câu Chuyện <br><span class="text-danger">Khởi Nguồn</span></h1>
                    <p class="lead text-muted mb-4" style="font-size: 1.1rem;">Hành trình của FastFood Store bắt đầu từ niềm đam mê mang những bữa ăn nhanh chất lượng, nóng hổi và đầy đủ dinh dưỡng đến cho cư dân thành phố.</p>
                    <div class="border-start border-4 border-danger ps-4 mb-4 py-2">
                        <p class="fst-italic text-dark fs-5 mb-0">"Chúng tôi mang đến sự tiện lợi và hương vị tuyệt vời cho nhịp sống hiện đại của Sài Gòn."</p>
                    </div>
                    <p class="text-muted mb-5">Khởi đầu tại trung tâm Quận 1, chúng tôi không ngừng tìm kiếm những nguồn nguyên liệu tươi ngon nhất để tạo nên những chiếc Burger giòn tan và những lát Pizza đậm đà chuẩn vị.</p>
                    <div class="d-flex gap-4">
                        <div class="text-center">
                            <h3 class="fw-bold text-danger mb-0">3+</h3>
                            <small class="text-muted">Năm kinh nghiệm</small>
                        </div>
                        <div class="vr"></div>
                        <div class="text-center">
                            <h3 class="fw-bold text-danger mb-0">30+</h3>
                            <small class="text-muted">Cửa hàng tại HCM</small>
                        </div>
                        <div class="vr"></div>
                        <div class="text-center">
                            <h3 class="fw-bold text-danger mb-0">500K+</h3>
                            <small class="text-muted">Khách hàng</small>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Right Image -->
            <div class="col-lg-6 position-relative" style="min-height: 500px;">
                <img src="https://images.unsplash.com/photo-1594212699903-ec8a3eca50f5?q=80&w=1200&auto=format&fit=crop"
                     class="position-absolute top-0 start-0 w-100 h-100"
                     style="object-fit: cover;"
                     alt="FastFood Store">
                <div class="position-absolute top-0 start-0 w-100 h-100"
                     style="background: linear-gradient(90deg, rgba(255,255,255,0.3) 0%, rgba(0,0,0,0) 100%);"></div>
                <!-- Badge overlay -->
                <div class="position-absolute bottom-0 start-0 m-4">
                    <div class="bg-danger text-white px-4 py-3 rounded-4 shadow-lg">
                        <h4 class="fw-bold mb-0">3+ Năm</h4>
                        <p class="small mb-0 opacity-75">Đồng hành cùng Sài Gòn</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Core Values Section -->
<section class="py-6 bg-light">
    <div class="container py-5">
        <div class="row text-center mb-5">
            <div class="col-lg-8 mx-auto">
                <h6 class="text-danger fw-bold text-uppercase letter-spacing mb-2">Triết lý</h6>
                <h2 class="fw-bold display-5">Giá trị <span class="text-danger">Cốt lõi</span></h2>
                <p class="text-muted">Những điều làm nên sự khác biệt của FastFood Store tại TP. Hồ Chí Minh.</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 p-4 text-center hover-translate">
                    <div class="icon-circle bg-danger-soft text-danger mx-auto mb-4">
                        <i class="fas fa-leaf fa-2x"></i>
                    </div>
                    <h4 class="fw-bold">Nguyên liệu Tươi</h4>
                    <p class="text-muted small">Nguyên liệu được nhập mới mỗi ngày từ các đối tác uy tín tại địa phương.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 p-4 text-center hover-translate">
                    <div class="icon-circle bg-warning-soft text-warning mx-auto mb-4">
                        <i class="fas fa-heart fa-2x"></i>
                    </div>
                    <h4 class="fw-bold">Tận Tâm</h4>
                    <p class="text-muted small">Phục vụ khách hàng bằng cả sự nhiệt huyết của người Sài Gòn.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 p-4 text-center hover-translate">
                    <div class="icon-circle bg-primary-soft text-primary mx-auto mb-4">
                        <i class="fas fa-bolt fa-2x"></i>
                    </div>
                    <h4 class="fw-bold">Nhanh Chóng</h4>
                    <p class="text-muted small">Giao hàng siêu tốc trong nội thành chỉ trong 30 phút.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Timeline Section -->
<section class="py-6 bg-white">
    <div class="container py-5">
        <div class="row text-center mb-5">
            <div class="col-lg-8 mx-auto">
                <h2 class="fw-bold display-5">Hành trình <span class="text-danger">phát triển</span></h2>
            </div>
        </div>
        <div class="row g-0">
            <div class="col-md-6 col-lg-3 text-center p-4">
                <div class="timeline-dot bg-danger text-white mx-auto mb-3">2021</div>
                <h5 class="fw-bold">Khởi đầu</h5>
                <p class="text-muted small">Mở cửa hàng đầu tiên tại Nguyễn Huệ, Quận 1.</p>
            </div>
            <div class="col-md-6 col-lg-3 text-center p-4">
                <div class="timeline-dot bg-danger text-white mx-auto mb-3">2022</div>
                <h5 class="fw-bold">Mở rộng</h5>
                <p class="text-muted small">Hiện diện tại Quận 3, Quận 7 và Quận 10.</p>
            </div>
            <div class="col-md-6 col-lg-3 text-center p-4">
                <div class="timeline-dot bg-danger text-white mx-auto mb-3">2023</div>
                <h5 class="fw-bold">Phủ sóng</h5>
                <p class="text-muted small">Đạt mốc 30 chi nhánh trên toàn địa bàn TP.HCM.</p>
            </div>
            <div class="col-md-6 col-lg-3 text-center p-4">
                <div class="timeline-dot bg-danger text-white mx-auto mb-3">2024</div>
                <h5 class="fw-bold">Công nghệ</h5>
                <p class="text-muted small">Hoàn thiện hệ thống E-commerce phục vụ hàng ngàn đơn mỗi ngày.</p>
            </div>
        </div>
    </div>
</section>

<style>
    .letter-spacing { letter-spacing: 2px; }
    .icon-circle {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }
    .bg-danger-soft { background-color: #ffe5e7; }
    .bg-warning-soft { background-color: #fff9db; }
    .bg-primary-soft { background-color: #e7f5ff; }
    .hover-translate { transition: transform 0.3s; }
    .hover-translate:hover { transform: translateY(-8px); }
    .timeline-dot {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
    }
    .py-6 { padding-top: 5rem; padding-bottom: 5rem; }
</style>

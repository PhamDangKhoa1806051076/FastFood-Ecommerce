@{
    ViewData["Title"] = "Tin tức & Sự kiện";
    Layout = "_Layout";
}

<!-- Page Header -->
<div class="bg-light border-bottom py-5 mb-5">
    <div class="container py-3 text-center">
        <h6 class="text-danger fw-bold text-uppercase letter-spacing mb-2">Cập nhật mới nhất</h6>
        <h1 class="display-4 fw-bold">Tin Tức & <span class="text-danger">Sự Kiện</span></h1>
        <p class="text-muted lead mb-0">Đừng bỏ lỡ những chương trình khuyến mãi và tin tức thú vị từ FastFood Store.</p>
    </div>
</div>

<div class="container pb-5">
    <!-- Featured News -->
    <div class="row g-4 mb-5">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 news-card">
                <div class="position-relative" style="height: 380px;">
                    <img src="https://images.unsplash.com/photo-1594212699903-ec8a3eca50f5?q=80&w=1200&auto=format&fit=crop"
                         class="w-100 h-100" style="object-fit: cover;" alt="Khai trương chi nhánh mới">
                    <div class="position-absolute bottom-0 start-0 w-100 p-4" style="background: linear-gradient(0deg, rgba(0,0,0,0.85) 0%, transparent 100%);">
                        <span class="badge bg-danger rounded-pill mb-2 px-3">Sự kiện nổi bật</span>
                        <h2 class="fw-bold text-white mb-2">Mở rộng hệ thống cửa hàng tại khu vực Thủ Đức</h2>
                        <p class="text-white-50 small mb-3">FastFood Store chính thức có mặt tại Gigamall Thủ Đức, mang hương vị Burger chuẩn Sài Gòn đến gần hơn với cư dân khu Đông...</p>
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="text-white-50 small"><i class="fas fa-calendar me-1"></i> 01/05/2026</span>
                            <a href="#" class="btn btn-danger btn-sm rounded-pill px-4">Đọc chi tiết</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="d-flex flex-column gap-4 h-100">
                <!-- Promo Card -->
                <div class="card border-0 rounded-4 overflow-hidden flex-fill news-card"
                     style="background: linear-gradient(135deg, #e63946 0%, #c1121f 100%); color: white; min-height: 160px;">
                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                        <div>
                            <span class="badge bg-white text-danger mb-2">Ưu đãi</span>
                            <h4 class="fw-bold">Ưu đãi thành viên mới</h4>
                            <p class="small opacity-75 mb-3">Giảm ngay 20% cho thành viên đăng ký trong tháng 5/2026.</p>
                        </div>
                        <a href="/Account/Register" class="text-white fw-bold small text-decoration-none d-flex align-items-center gap-2">
                            Đăng ký ngay <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
                <!-- Award Card -->
                <div class="card border-0 rounded-4 overflow-hidden flex-fill news-card"
                     style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: #1a1a1a; min-height: 160px;">
                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                        <div>
                            <span class="badge bg-dark text-warning mb-2">Giải thưởng</span>
                            <h4 class="fw-bold">Chuỗi FastFood yêu thích nhất</h4>
                            <p class="small opacity-75 mb-3">FastFood Store nhận giải thưởng uy tín từ Hiệp hội Ẩm thực 2025.</p>
                        </div>
                        <a href="#" class="text-dark fw-bold small text-decoration-none d-flex align-items-center gap-2">
                            Xem thêm <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- News Category Tabs -->
    <ul class="nav nav-pills border-bottom pb-3 mb-4 gap-2">
        <li class="nav-item"><a class="nav-link active bg-danger" href="#">Tất cả</a></li>
        <li class="nav-item"><a class="nav-link text-dark" href="#">Khuyến mãi</a></li>
        <li class="nav-item"><a class="nav-link text-dark" href="#">Sản phẩm mới</a></li>
        <li class="nav-item"><a class="nav-link text-dark" href="#">Sự kiện</a></li>
    </ul>

    <!-- News Grid -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden news-card">
                <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=600&auto=format&fit=crop"
                     class="card-img-top" style="height: 200px; object-fit: cover;" alt="Burger mới">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="badge bg-danger-soft text-danger rounded-pill px-3">Sản phẩm mới</span>
                        <span class="text-muted small">05/05/2026</span>
                    </div>
                    <h5 class="fw-bold mb-2">Burger Bò Wagyu - Siêu phẩm mùa hè</h5>
                    <p class="text-muted small mb-0">Thịt bò Wagyu nhập khẩu, phô mai Cheddar tan chảy, sốt đặc biệt bí truyền...</p>
                </div>
                <div class="card-footer bg-white border-0 p-4 pt-0">
                    <a href="#" class="btn btn-link text-danger p-0 text-decoration-none fw-bold small">
                        Đọc tiếp <i class="fas fa-chevron-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden news-card">
                <img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?q=80&w=600&auto=format&fit=crop"
                     class="card-img-top" style="height: 200px; object-fit: cover;" alt="Pizza mới">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="badge bg-warning-soft text-warning rounded-pill px-3">Khuyến mãi</span>
                        <span class="text-muted small">03/05/2026</span>
                    </div>
                    <h5 class="fw-bold mb-2">Combo Gia Đình tiết kiệm tới 30%</h5>
                    <p class="text-muted small mb-0">Thưởng thức trọn bộ các món ngon nhất cùng gia đình với mức giá cực kỳ hấp dẫn...</p>
                </div>
                <div class="card-footer bg-white border-0 p-4 pt-0">
                    <a href="#" class="btn btn-link text-danger p-0 text-decoration-none fw-bold small">
                        Đọc tiếp <i class="fas fa-chevron-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden news-card">
                <img src="https://images.unsplash.com/photo-1550547660-d9450f859349?q=80&w=600&auto=format&fit=crop"
                     class="card-img-top" style="height: 200px; object-fit: cover;" alt="Ưu đãi">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="badge bg-primary-soft text-primary rounded-pill px-3">Sự kiện</span>
                        <span class="text-muted small">28/04/2026</span>
                    </div>
                    <h5 class="fw-bold mb-2">Lễ hội Burger tháng 5 - Lần đầu tại Việt Nam</h5>
                    <p class="text-muted small mb-0">Hàng ngàn suất bánh mì, burger và đồ ăn nhanh miễn phí chào đón tháng 5...</p>
                </div>
                <div class="card-footer bg-white border-0 p-4 pt-0">
                    <a href="#" class="btn btn-link text-danger p-0 text-decoration-none fw-bold small">
                        Đọc tiếp <i class="fas fa-chevron-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .letter-spacing { letter-spacing: 2px; }
    .news-card { transition: transform 0.3s, box-shadow 0.3s; }
    .news-card:hover { transform: translateY(-6px); box-shadow: 0 15px 40px rgba(0,0,0,0.1) !important; }
    .bg-danger-soft { background-color: #fff0f1; }
    .bg-warning-soft { background-color: #fffbeb; }
    .bg-primary-soft { background-color: #eff6ff; }
    .nav-pills .nav-link.active { color: white !important; }
    .nav-pills .nav-link:not(.active):hover { background-color: #f0f0f0; }
</style>

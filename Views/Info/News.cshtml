@{
    ViewData["Title"] = "Tin tức FastFood";
}

<div class="container py-5">
    <div class="text-center mb-5 pb-3">
        <h6 class="text-danger fw-bold text-uppercase mb-2">Cập nhật mới nhất</h6>
        <h1 class="display-4 fw-bold">Tin Tức & <span class="text-danger">Sự Kiện</span></h1>
        <p class="text-muted lead">Đừng bỏ lỡ những chương trình khuyến mãi và tin tức thú vị từ FastFood Store.</p>
    </div>

    <!-- Featured News -->
    <div class="row g-4 mb-5">
        <div class="col-lg-8">
            <div class="card h-100 border-0 shadow-sm rounded-5 overflow-hidden position-relative group">
                <img src="/news_hero_1778037894181.png" class="w-100 h-100" style="object-fit: cover;">
                <div class="position-absolute bottom-0 start-0 w-100 p-5 bg-gradient-dark text-white">
                    <span class="badge bg-danger mb-3">Sự kiện nổi bật</span>
                    <h2 class="fw-bold mb-3">Khai trương chi nhánh thứ 50 tại TP. Hồ Chí Minh</h2>
                    <p class="mb-4 text-white-50">Chào mừng cột mốc mới, FastFood Store tung ra hàng ngàn ưu đãi Mua 1 Tặng 1 dành riêng cho khách hàng tham dự buổi khai trương...</p>
                    <a href="#" class="btn btn-white bg-white rounded-pill px-4 fw-bold text-dark">Đọc chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="d-flex flex-column gap-4 h-100">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-50 d-flex flex-column justify-content-center bg-danger text-white">
                    <h4 class="fw-bold mb-2">Ưu đãi Member</h4>
                    <p class="small text-white-50">Giảm ngay 20% cho thành viên mới đăng ký trong tháng này.</p>
                    <a href="/Account/Register" class="text-white fw-bold small text-decoration-none">Đăng ký ngay <i class="fas fa-arrow-right ms-2"></i></a>
                </div>
                <div class="card border-0 shadow-sm rounded-4 p-4 h-50 d-flex flex-column justify-content-center bg-warning text-dark">
                    <h4 class="fw-bold mb-2">Tin nội bộ</h4>
                    <p class="small text-dark-50">FastFood Store nhận giải thưởng "Chuỗi cửa hàng thức ăn nhanh được yêu thích nhất 2025".</p>
                    <a href="#" class="text-dark fw-bold small text-decoration-none">Xem thêm <i class="fas fa-arrow-right ms-2"></i></a>
                </div>
            </div>
        </div>
    </div>

    <!-- News Grid -->
    <div class="row g-4">
        @for (int i = 1; i <= 3; i++)
        {
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-up transition">
                    <img src="https://images.unsplash.com/photo-1550547660-d9450f859349?q=80&w=600" class="card-img-top" style="height: 200px; object-fit: cover;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-danger fw-bold small">Khuyến mãi</span>
                            <span class="text-muted small">06/05/2026</span>
                        </div>
                        <h5 class="fw-bold mb-3">Combo Gia Đình tiết kiệm tới 30%</h5>
                        <p class="text-muted small mb-0">Thưởng thức trọn bộ các món ngon nhất cùng gia đình với mức giá cực kỳ hấp dẫn chỉ trong mùa hè này...</p>
                    </div>
                    <div class="card-footer bg-white border-0 p-4 pt-0">
                        <a href="#" class="btn btn-link text-danger p-0 text-decoration-none fw-bold small">Đọc tiếp <i class="fas fa-chevron-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .bg-gradient-dark {
        background: linear-gradient(0deg, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0) 100%);
    }
    .hover-up { transition: all 0.3s; }
    .hover-up:hover { transform: translateY(-10px); }
    .transition { transition: all 0.3s; }
</style>

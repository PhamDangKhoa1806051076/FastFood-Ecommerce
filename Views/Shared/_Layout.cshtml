@using FastFoodEcommerce.Helpers
@using FastFoodEcommerce.Models
@using FastFoodEcommerce.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@{
    var cartCount = Context.Session.GetObjectFromJson<List<CartItem>>("FastFoodCart")?.Sum(x => x.Quantity) ?? 0;
    var currentCulture = Context.Request.Cookies["FastFoodLanguage"] ?? "vi";
    string T(string key) => LanguageHelper.Get(key, currentCulture);

    var userEmail = Context.Session.GetString("UserEmail");
    var userRole = Context.Session.GetString("UserRole");

    // Fetch Banners for Layout
    var topBanner = DbContext.Banners.AsNoTracking().Where(b => b.IsActive && b.DisplayOrder < 0).OrderBy(b => b.DisplayOrder).FirstOrDefault();
    var bottomBanner = DbContext.Banners.AsNoTracking().Where(b => b.IsActive && b.DisplayOrder >= 100).OrderBy(b => b.DisplayOrder).FirstOrDefault();
}
<!DOCTYPE html>
<html lang="@currentCulture" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FastFood Store | Thưởng thức món ngon chuẩn vị</title>
    <meta name="description" content="FastFood Store - Hệ thống cửa hàng thức ăn nhanh hàng đầu với các món Burger, Pizza, Gà giòn thơm ngon. Đặt hàng ngay để nhận nhiều ưu đãi hấp dẫn." />
    <meta name="keywords" content="fast food, burger, pizza, gà rán, thức ăn nhanh, đặt đồ ăn online, fastfood store" />
    <meta property="og:title" content="@ViewData["Title"] - FastFood Store" />
    <meta property="og:description" content="Thưởng thức các món ăn nhanh thơm ngon, nóng hổi tại FastFood Store. Giao hàng nhanh chóng, ưu đãi ngập tràn." />
    <meta property="og:image" content="/images/logo-og.png" />
    <meta property="og:type" content="website" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="@(Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path)" />
    @await RenderSectionAsync("MetaTags", required: false)
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FastFoodEcommerce.styles.css" asp-append-version="true" />
    <style>
        .top-promo-bar {
            background: linear-gradient(90deg, #e63946 0%, #d62828 100%);
            color: white;
            padding: 8px 0;
            font-size: 0.85rem;
            text-align: center;
            font-weight: 600;
            letter-spacing: 0.5px;
        }
        .bottom-promo-banner {
            background: #f8f9fa;
            border-radius: 20px;
            overflow: hidden;
            margin-bottom: 50px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        .hover-white:hover { color: white !important; }
        .social-icon {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: #333;
            color: white;
            transition: all 0.3s;
        }
        .social-icon:hover { background: #e63946; transform: translateY(-3px); }
    </style>
</head>
<body>
    @if (topBanner != null)
    {
        <div class="top-promo-bar animate__animated animate__fadeInDown">
            <a href="@(topBanner.LinkUrl ?? "#")" class="text-white text-decoration-none">
                <i class="fas fa-bullhorn me-2"></i> @topBanner.Title: @topBanner.SubTitle
            </a>
        </div>
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top py-3">
            <div class="container-fluid px-5">
                <!-- Logo bên trái -->
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-hamburger fa-2x text-danger me-2"></i>
                    <span class="fw-bold fs-3 text-dark">FastFood Store</span>
                </a>

                <!-- Nút toggle cho mobile -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Menu ở giữa và Icons bên phải -->
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 fw-bold text-uppercase">
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-area="" asp-controller="Home" asp-action="Index">@T("Home")</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/Home/Index#menu-section">@T("Menu")</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Promotion" asp-action="Index">@T("Promotion")</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Store" asp-action="Index">@T("Stores")</a>
                        </li>
                        @if (userRole == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 text-primary fw-bold" asp-controller="Admin" asp-action="Index">Admin Area</a>
                            </li>
                        }
                    </ul>
                    
                    <div class="d-flex align-items-center gap-4">
                        <!-- Theme Toggle Button -->
                        <button id="themeToggleBtn" class="btn btn-link text-dark p-0 fs-5 text-decoration-none me-3" title="Chế độ Sáng/Tối">
                            <i class="fas fa-sun" id="themeIcon"></i>
                        </button>

                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle fw-bold small text-dark p-0 d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                                @(currentCulture == "vi" ? "🇻🇳" : currentCulture == "ko" ? "🇰🇷" : "🇺🇸") @T("Language")
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3 mt-2">
                                <li><a class="dropdown-item py-2 d-flex align-items-center gap-2" asp-controller="Home" asp-action="ChangeLanguage" asp-route-culture="en"><span>🇺🇸</span> @T("English")</a></li>
                                <li><a class="dropdown-item py-2 d-flex align-items-center gap-2" asp-controller="Home" asp-action="ChangeLanguage" asp-route-culture="vi"><span>🇻🇳</span> @T("Vietnamese")</a></li>
                                <li><a class="dropdown-item py-2 d-flex align-items-center gap-2" asp-controller="Home" asp-action="ChangeLanguage" asp-route-culture="ko"><span>🇰🇷</span> @T("Korean")</a></li>
                            </ul>
                        </div>

                        <div class="dropdown">
                            <a class="text-dark fs-5" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="far fa-user-circle"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3 mt-2">
                                @if (string.IsNullOrEmpty(userEmail))
                                {
                                    <li><a class="dropdown-item py-2" asp-controller="Account" asp-action="Login">@T("Login")</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Account" asp-action="Register">@T("Register")</a></li>
                                }
                                else
                                {
                                    <li><span class="dropdown-item-text small text-muted">@userEmail</span></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Account" asp-action="Orders">@T("TrackOrder")</a></li>
                                    <li><a class="dropdown-item py-2 text-warning fw-bold" asp-controller="Account" asp-action="Loyalty"><i class="fas fa-star me-2"></i>Điểm thưởng & Ưu đãi</a></li>
                                    <li><a class="dropdown-item py-2 text-danger" asp-controller="Account" asp-action="Logout">@T("Logout")</a></li>
                                }
                            </ul>
                        </div>
                        <a asp-controller="Cart" asp-action="Index" class="text-dark fs-5 position-relative" title="@T("Cart")">
                            <i class="fas fa-shopping-basket"></i>
                            @if (cartCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                                    @cartCount
                                </span>
                            }
                        </a>
                        <a href="#" class="text-dark fs-5" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
                            <i class="fas fa-bars"></i>
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    @if (bottomBanner != null)
    {
        <div class="container mt-5">
            <div class="bottom-promo-banner animate__animated animate__fadeInUp">
                <div class="row g-0 align-items-center">
                    <div class="col-md-7 p-5">
                        <span class="badge bg-danger mb-3 px-3 py-2 rounded-pill text-uppercase">Ưu đãi đặc biệt</span>
                        <h2 class="display-5 fw-bold mb-3">@bottomBanner.Title</h2>
                        <p class="lead text-muted mb-4">@bottomBanner.SubTitle</p>
                        @if (!string.IsNullOrEmpty(bottomBanner.LinkUrl))
                        {
                            <a href="@bottomBanner.LinkUrl" class="btn btn-dark btn-lg px-5 rounded-pill fw-bold">Khám phá ngay</a>
                        }
                    </div>
                    <div class="col-md-5">
                        <img src="@bottomBanner.ImageUrl" class="img-fluid w-100" style="height: 350px; object-fit: cover;" alt="@bottomBanner.Title">
                    </div>
                </div>
            </div>
        </div>
    }

    <footer class="bg-dark text-white py-5 mt-5 border-top border-secondary">
        <div class="container py-4">
            <div class="row g-4">
                <!-- Column 1: Về FastFood -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold text-uppercase mb-4">Về FastFood</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a asp-controller="Info" asp-action="OurStory" class="text-secondary text-decoration-none hover-white">Câu chuyện của chúng tôi</a></li>
                        <li class="mb-2"><a asp-controller="Info" asp-action="News" class="text-secondary text-decoration-none hover-white">Tin tức FastFood</a></li>
                        <li class="mb-2"><a asp-controller="Info" asp-action="Recruitment" class="text-secondary text-decoration-none hover-white">Tuyển dụng</a></li>
                    </ul>
                </div>
                
                <!-- Column 2: System -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold text-uppercase mb-4">Hệ thống FastFood</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="/Home/Index#menu-section" class="text-secondary text-decoration-none hover-white">Thực đơn</a></li>
                        <li class="mb-2"><a asp-controller="Promotion" asp-action="Index" class="text-secondary text-decoration-none hover-white">Khuyến mãi</a></li>
                        <li class="mb-2"><a asp-controller="Store" asp-action="Index" class="text-secondary text-decoration-none hover-white">Hệ thống cửa hàng</a></li>
                    </ul>
                </div>

                <!-- Column 3: Contact -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold text-uppercase mb-4">@T("ContactUs")</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white">@T("TrackOrder")</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white">@T("StoreSystem")</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white">@T("ContactUs")</a></li>
                    </ul>
                </div>

                <!-- Column 4: Policy -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold text-uppercase mb-4">@T("Policy")</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white">@T("OurPolicy")</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white">@T("Terms")</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white">@T("PrivacyPolicy")</a></li>
                    </ul>
                </div>
            </div>

            <hr class="my-5 border-secondary">

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-4">
                <div class="text-secondary small">
                    Copyright © 2026 FastFood Store
                </div>
                <div class="d-flex gap-3">
                    <a href="#" class="social-icon"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                    <a href="#" class="social-icon"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
        </div>
    </footer>



    <!-- Offcanvas Sidebar Menu -->
    <div class="offcanvas offcanvas-end border-0 shadow" tabindex="-1" id="sidebarMenu" style="width: 350px;">
        <div class="offcanvas-header border-bottom py-4">
            <h5 class="offcanvas-title fw-bold text-uppercase" id="sidebarMenuLabel">@T("Menu")</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <div class="list-group list-group-flush">
                <a href="/Home/Index#menu-section" class="list-group-item list-group-item-action py-3 px-4 border-0 d-flex justify-content-between align-items-center">
                    <span>@T("Menu")</span>
                    <i class="fas fa-chevron-right small text-muted"></i>
                </a>
                <a asp-controller="Promotion" asp-action="Index" class="list-group-item list-group-item-action py-3 px-4 border-0 d-flex justify-content-between align-items-center">
                    <span>@T("Promotion")</span>
                    <i class="fas fa-chevron-right small text-muted"></i>
                </a>
                <a asp-controller="Store" asp-action="Index" class="list-group-item list-group-item-action py-3 px-4 border-0 d-flex justify-content-between align-items-center">
                    <span>@T("FindStore")</span>
                    <i class="fas fa-chevron-right small text-muted"></i>
                </a>
            </div>
            
            <div class="p-4 mt-4">
                <h6 class="fw-bold text-uppercase small text-muted mb-3">Về FastFood</h6>
                <ul class="list-unstyled">
                    <li class="mb-2"><a asp-controller="Info" asp-action="OurStory" class="text-decoration-none text-dark small">Câu chuyện của chúng tôi</a></li>
                    <li class="mb-2"><a asp-controller="Info" asp-action="News" class="text-decoration-none text-dark small">Tin tức FastFood</a></li>
                    <li class="mb-2"><a asp-controller="Info" asp-action="Recruitment" class="text-decoration-none text-dark small">Tuyển dụng</a></li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Scroll to Top Button -->
    <button id="scrollToTopBtn" class="btn btn-danger rounded-circle shadow-lg" title="Lên đầu trang" style="display: none; position: fixed; bottom: 40px; right: 40px; z-index: 9999; width: 55px; height: 55px; border: none; background-color: #e63946; color: white; cursor: pointer; padding: 0; transition: transform 0.2s;">
        <i class="fas fa-arrow-up fs-4"></i>
    </button>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.min.js" asp-append-version="true"></script>

    <script>
        // Dark Mode Logic
        $(document).ready(function() {
            var currentTheme = localStorage.getItem('theme') || 'light';
            if (currentTheme === 'dark') {
                $('html').attr('data-bs-theme', 'dark');
                $('#themeIcon').removeClass('fa-sun').addClass('fa-moon');
                $('#themeToggleBtn').removeClass('text-dark').addClass('text-light');
            } else {
                $('html').attr('data-bs-theme', 'light');
                $('#themeIcon').removeClass('fa-moon').addClass('fa-sun');
                $('#themeToggleBtn').removeClass('text-light').addClass('text-dark');
            }

            $('#themeToggleBtn').click(function() {
                var theme = $('html').attr('data-bs-theme');
                if (theme === 'dark') {
                    $('html').attr('data-bs-theme', 'light');
                    $('#themeIcon').removeClass('fa-moon').addClass('fa-sun');
                    $(this).removeClass('text-light').addClass('text-dark');
                    localStorage.setItem('theme', 'light');
                } else {
                    $('html').attr('data-bs-theme', 'dark');
                    $('#themeIcon').removeClass('fa-sun').addClass('fa-moon');
                    $(this).removeClass('text-dark').addClass('text-light');
                    localStorage.setItem('theme', 'dark');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

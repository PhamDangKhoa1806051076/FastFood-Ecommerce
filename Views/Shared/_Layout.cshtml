@using FastFoodEcommerce.Helpers
@using FastFoodEcommerce.Models
@{
    var cartCount = Context.Session.GetObjectFromJson<List<CartItem>>("FastFoodCart")?.Sum(x => x.Quantity) ?? 0;
    var currentCulture = Context.Request.Cookies["FastFoodLanguage"] ?? "en";
    var langDisplay = currentCulture switch
    {
        "vi" => "Tiếng Việt",
        "ko" => "한국어",
        _ => "English"
    };
}
<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FastFood Store</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FastFoodEcommerce.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top py-3">
            <div class="container-fluid px-5">
                <!-- Logo bên trái -->
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-hamburger fa-2x text-danger me-2"></i>
                    <span class="fw-bold fs-3 text-dark">FastFood Store</span>
                </a>

                <!-- Nút toggle cho mobile -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Menu ở giữa và Icons bên phải -->
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 fw-bold text-uppercase">
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/Home/Index#menu-section">Thực đơn</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Promotion" asp-action="Index">Khuyến mãi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Store" asp-action="Index">Hệ thống cửa hàng</a>
                        </li>
                    </ul>
                    
                    <div class="d-flex align-items-center gap-4">
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle fw-bold small text-dark p-0" href="#" role="button" data-bs-toggle="dropdown">
                                @langDisplay
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3 mt-2">
                                <li><a class="dropdown-item py-2" asp-controller="Home" asp-action="ChangeLanguage" asp-route-culture="en">English</a></li>
                                <li><a class="dropdown-item py-2" asp-controller="Home" asp-action="ChangeLanguage" asp-route-culture="vi">Tiếng Việt</a></li>
                                <li><a class="dropdown-item py-2" asp-controller="Home" asp-action="ChangeLanguage" asp-route-culture="ko">한국어</a></li>
                            </ul>
                        </div>
                        <a asp-controller="Account" asp-action="Login" class="text-dark fs-5">
                            <i class="far fa-user-circle"></i>
                        </a>
                        <a asp-controller="Cart" asp-action="Index" class="text-dark fs-5 position-relative">
                            <i class="fas fa-shopping-basket"></i>
                            @if (cartCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                                    @cartCount
                                </span>
                            }
                        </a>
                        <a href="#" class="text-dark fs-5" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu">
                            <i class="fas fa-bars"></i>
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            &copy; 2026 - FastFood Store - <a href="#">Liên hệ</a>
        </div>
    </footer>
    <!-- Offcanvas Sidebar Menu -->
    <div class="offcanvas offcanvas-end border-0 shadow" tabindex="-1" id="sidebarMenu" style="width: 350px;">
        <div class="offcanvas-header border-bottom py-4">
            <h5 class="offcanvas-title fw-bold text-uppercase" id="sidebarMenuLabel">Danh mục món ăn</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <div class="list-group list-group-flush">
                <a href="/Home/Index#menu-section" class="list-group-item list-group-item-action py-3 px-4 border-0 d-flex justify-content-between align-items-center">
                    <span>Thực đơn chính</span>
                    <i class="fas fa-chevron-right small text-muted"></i>
                </a>
                <a asp-controller="Promotion" asp-action="Index" class="list-group-item list-group-item-action py-3 px-4 border-0 d-flex justify-content-between align-items-center">
                    <span>Khuyến mãi mới nhất</span>
                    <i class="fas fa-chevron-right small text-muted"></i>
                </a>
                <a asp-controller="Store" asp-action="Index" class="list-group-item list-group-item-action py-3 px-4 border-0 d-flex justify-content-between align-items-center">
                    <span>Tìm cửa hàng gần đây</span>
                    <i class="fas fa-chevron-right small text-muted"></i>
                </a>
            </div>
            
            <div class="p-4 mt-4">
                <h6 class="fw-bold text-uppercase small text-muted mb-3">Về chúng tôi</h6>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="#" class="text-decoration-none text-dark small">Câu chuyện của chúng tôi</a></li>
                    <li class="mb-2"><a href="#" class="text-decoration-none text-dark small">Tin tức FastFood</a></li>
                    <li class="mb-2"><a href="#" class="text-decoration-none text-dark small">Tuyển dụng</a></li>
                </ul>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
